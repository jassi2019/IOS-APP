<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Payment Receipt - Taiyari NEET Ki</title>
</head>
<body style="margin:0;padding:0;background-color:#f4f4f7;font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f4f7;padding:30px 0;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" style="background-color:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.08);">
          <!-- Header -->
          <tr>
            <td style="background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);padding:30px 40px;text-align:center;">
              <h1 style="color:#ffffff;margin:0;font-size:24px;font-weight:700;">Taiyari NEET Ki</h1>
              <p style="color:#c7d2fe;margin:8px 0 0;font-size:14px;">Payment Receipt</p>
            </td>
          </tr>

          <!-- Success Icon -->
          <tr>
            <td style="padding:30px 40px 10px;text-align:center;">
              <div style="width:64px;height:64px;background-color:#dcfce7;border-radius:50%;display:inline-block;line-height:64px;font-size:32px;">
                &#10003;
              </div>
              <h2 style="color:#111827;margin:16px 0 4px;font-size:22px;">Payment Successful!</h2>
              <p style="color:#6b7280;margin:0;font-size:14px;">Thank you for your purchase, {{userName}}!</p>
            </td>
          </tr>

          <!-- Invoice Details -->
          <tr>
            <td style="padding:20px 40px;">
              <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f9fafb;border-radius:8px;border:1px solid #e5e7eb;">
                <tr>
                  <td style="padding:20px;">
                    <table width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="padding:8px 0;color:#6b7280;font-size:13px;border-bottom:1px solid #e5e7eb;">Invoice No.</td>
                        <td style="padding:8px 0;color:#111827;font-size:13px;font-weight:600;text-align:right;border-bottom:1px solid #e5e7eb;">{{invoiceNo}}</td>
                      </tr>
                      <tr>
                        <td style="padding:8px 0;color:#6b7280;font-size:13px;border-bottom:1px solid #e5e7eb;">Date</td>
                        <td style="padding:8px 0;color:#111827;font-size:13px;font-weight:600;text-align:right;border-bottom:1px solid #e5e7eb;">{{date}}</td>
                      </tr>
                      <tr>
                        <td style="padding:8px 0;color:#6b7280;font-size:13px;border-bottom:1px solid #e5e7eb;">Plan</td>
                        <td style="padding:8px 0;color:#111827;font-size:13px;font-weight:600;text-align:right;border-bottom:1px solid #e5e7eb;">{{planName}}</td>
                      </tr>
                      <tr>
                        <td style="padding:8px 0;color:#6b7280;font-size:13px;border-bottom:1px solid #e5e7eb;">Valid Until</td>
                        <td style="padding:8px 0;color:#111827;font-size:13px;font-weight:600;text-align:right;border-bottom:1px solid #e5e7eb;">{{validUntil}}</td>
                      </tr>
                      <tr>
                        <td style="padding:8px 0;color:#6b7280;font-size:13px;border-bottom:1px solid #e5e7eb;">Payment ID</td>
                        <td style="padding:8px 0;color:#111827;font-size:13px;font-weight:600;text-align:right;border-bottom:1px solid #e5e7eb;">{{paymentId}}</td>
                      </tr>
                      <tr>
                        <td style="padding:8px 0;color:#6b7280;font-size:13px;border-bottom:1px solid #e5e7eb;">Payment Method</td>
                        <td style="padding:8px 0;color:#111827;font-size:13px;font-weight:600;text-align:right;border-bottom:1px solid #e5e7eb;">{{platform}}</td>
                      </tr>
                      <tr>
                        <td style="padding:12px 0 8px;color:#111827;font-size:15px;font-weight:700;">Total Amount</td>
                        <td style="padding:12px 0 8px;color:#4F46E5;font-size:18px;font-weight:700;text-align:right;">&#8377; {{amount}}</td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Status -->
          <tr>
            <td style="padding:10px 40px 20px;text-align:center;">
              <span style="display:inline-block;background-color:#dcfce7;color:#166534;padding:6px 16px;border-radius:20px;font-size:13px;font-weight:600;">
                &#10003; Payment Verified
              </span>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding:20px 40px;background-color:#f9fafb;border-top:1px solid #e5e7eb;text-align:center;">
              <p style="color:#9ca3af;font-size:12px;margin:0;">
                This is an auto-generated receipt from Taiyari NEET Ki.<br/>
                For any queries, contact us at support@taiyarineetki.com
              </p>
              <p style="color:#d1d5db;font-size:11px;margin:12px 0 0;">
                &copy; {{year}} Taiyari NEET Ki. All rights reserved.
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
